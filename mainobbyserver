local function createCheckpointModel(stageIndex, platformCFrame, platformSize, parent)
	local model = Instance.new("Model")
	model.Name = "Stage_" .. stageIndex
	model.Parent = parent

	local plat = makePart({
		Name = "Platform",
		Size = platformSize,
		CFrame = platformCFrame,
		Color = chooseColor(stageIndex),
	})
	addPointLight(plat, plat.Color, 2.2, 28)
	plat.Parent = model

	local circle = makePart({
		Name = "CheckpointCircle",
		Size = Vector3.new(CHECKPOINT_RADIUS * 2, CHECKPOINT_THICKNESS, CHECKPOINT_RADIUS * 2),
		CFrame = platformCFrame * CFrame.new(0, platformSize.Y / 2 + CHECKPOINT_THICKNESS / 2 + 0.05, 0),
		Color = COLOR_NEON_PINK,
		CanCollide = false,
	})
	circle.Shape = Enum.PartType.Cylinder
	circle.Orientation = Vector3.new(0, 0, 90)
	addPointLight(circle, COLOR_NEON_PINK, 2.5, 20)
	circle.Parent = model

	local checkHolder = Instance.new("Part")
	checkHolder.Name = "CheckVisual"
	checkHolder.Anchored = true
	checkHolder.CanCollide = false
	checkHolder.CanTouch = false
	checkHolder.CanQuery = false
	checkHolder.Transparency = 1
	checkHolder.Size = Vector3.new(2, 2, 2)
	checkHolder.CFrame = platformCFrame * CFrame.new(0, platformSize.Y / 2 + 6, 0)
	checkHolder.Parent = model

	local bb = Instance.new("BillboardGui")
	bb.Name = "CheckBillboard"
	bb.AlwaysOnTop = true
	bb.Size = UDim2.fromOffset(120, 120)
	bb.Enabled = false
	bb.Parent = checkHolder

	local txt = Instance.new("TextLabel")
	txt.BackgroundTransparency = 1
	txt.Size = UDim2.fromScale(1, 1)
	txt.Text = "✓"
	txt.TextScaled = true
	txt.Font = Enum.Font.GothamBlack
	txt.TextColor3 = COLOR_NEON_GREEN
	txt.TextStrokeTransparency = 0.35
	txt.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
	txt.Parent = bb

	local activated = Instance.new("BoolValue")
	activated.Name = "Activated"
	activated.Value = false
	activated.Parent = model

	local s = Instance.new("Sound")
	s.Name = "CheckpointSound"
	s.SoundId = "rbxassetid://911342077"
	s.Volume = 0.7
	s.Parent = circle

	return model, circle, activated, bb
end

