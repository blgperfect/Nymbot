local function makeKillPart(cf, size, parent)
	local p = makePart({
		Name = "KillPart",
		Size = size,
		CFrame = cf,
		Color = COLOR_BLACK_KILL,
		Material = Enum.Material.Neon,
	})
	addPointLight(p, Color3.fromRGB(30, 30, 30), 1.0, 18)
	p.Parent = parent
	p.Touched:Connect(function(hit)
		local hum = hit.Parent and hit.Parent:FindFirstChildOfClass("Humanoid")
		if hum and hum.Health > 0 then hum.Health = 0 end
	end)
	return p
end

local function makeNarrowBeam(cf, length, parent, color)
	local beam = makePart({
		Name = "NarrowBeam",
		Size = Vector3.new(5, 2, length),
		CFrame = cf,
		Color = color,
	})
	addPointLight(beam, color, 1.8, 22)
	beam.Parent = parent
	return beam
end

local function makeSmallJumpPads(startCf, count, spacing, parent, stageIndex)
	local col = chooseColor(stageIndex)
	for i = 1, count do
		local sz = Vector3.new(
			clamp(10 - math.floor(stageIndex / 10), 5, 10),
			2,
			clamp(10 - math.floor(stageIndex / 10), 5, 10)
		)
		local pad = makePart({
			Name = "JumpPad_" .. i,
			Size = sz,
			CFrame = startCf * CFrame.new(0, 0, (i - 1) * spacing),
			Color = col,
		})
		addPointLight(pad, col, 1.8, 18)
		pad.Parent = parent

		if (i % 2 == 0) and (stageIndex >= 8) then
			local k = makeKillPart(pad.CFrame * CFrame.new(0, -7, 0), Vector3.new(sz.X + 6, 1.5, sz.Z + 6), parent)
			k.Transparency = 0.05
		end
	end
end

local function makeMovingPlatform(cf, size, axis, distance, period, parent, color)
	local plat = makePart({
		Name = "MovingPlatform",
		Size = size,
		CFrame = cf,
		Color = color,
	})
	addPointLight(plat, color, 2.0, 20)
	plat.Parent = parent

	local dir = (axis == "X") and Vector3.new(1, 0, 0) or (axis == "Z") and Vector3.new(0, 0, 1) or Vector3.new(0, 1, 0)
	local target = cf * CFrame.new(dir * distance)

	local ti = TweenInfo.new(period, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut, -1, true)
	local tween = TweenService:Create(plat, ti, { CFrame = target })
	tween:Play()

	return plat
end

local function makeSpinner(cf, radius, bladeLen, bladeCount, rpm, parent, color)
	local spinnerModel = Instance.new("Model")
	spinnerModel.Name = "Spinner"
	spinnerModel.Parent = parent

	local center = makePart({
		Name = "SpinnerCenter",
		Size = Vector3.new(4, 4, 4),
		CFrame = cf,
		Color = color,
		CanCollide = true,
	})
	addPointLight(center, color, 2.0, 22)
	center.Parent = spinnerModel

	for i = 1, bladeCount do
		local angle = (i / bladeCount) * math.pi * 2
		local blade = makePart({
			Name = "Blade_" .. i,
			Size = Vector3.new(2.2, 1.2, bladeLen),
			CFrame = cf * CFrame.Angles(0, angle, 0) * CFrame.new(0, 0, bladeLen / 2 + radius),
			Color = COLOR_BLACK_KILL,
			Material = Enum.Material.Neon,
		})
		blade.Parent = spinnerModel
		blade.Touched:Connect(function(hit)
			local hum = hit.Parent and hit.Parent:FindFirstChildOfClass("Humanoid")
			if hum and hum.Health > 0 then hum.Health = 0 end
		end)
	end

	local angVel = (rpm * 2 * math.pi) / 60
	local current = 0
	RunService.Heartbeat:Connect(function(dt)
		if spinnerModel.Parent == nil then return end
		current += angVel * dt

		for _, child in ipairs(spinnerModel:GetChildren()) do
			if child:IsA("Part") and child.Name == "SpinnerCenter" then
				child.CFrame = cf * CFrame.Angles(0, current, 0)
			elseif child:IsA("Part") and child.Name:match("^Blade_") then
				local idx = tonumber(child.Name:match("Blade_(%d+)")) or 1
				local a = (idx / bladeCount) * math.pi * 2 + current
				child.CFrame = cf * CFrame.Angles(0, a, 0) * CFrame.new(0, 0, bladeLen / 2 + radius)
			end
		end
	end)

	return spinnerModel
end

local function makeFallingPlatform(cf, size, parent, color)
	local plat = makePart({
		Name = "FallingPlatform",
		Size = size,
		CFrame = cf,
		Color = color,
	})
	addPointLight(plat, color, 2.0, 18)
	plat.Parent = parent

	local busy = false
	local originalCf = cf

	plat.Touched:Connect(function(hit)
		if busy then return end
		local hum = hit.Parent and hit.Parent:FindFirstChildOfClass("Humanoid")
		if not hum then return end
		busy = true

		task.delay(0.15, function()
			if plat.Parent == nil then return end
			plat.Anchored = false
		end)

		task.delay(3.0, function()
			if plat.Parent == nil then return end
			plat.Anchored = true
			plat.AssemblyLinearVelocity = Vector3.zero
			plat.AssemblyAngularVelocity = Vector3.zero
			plat.CFrame = originalCf
			busy = false
		end)
	end)

	return plat
end

local function buildObstaclePack(stageIndex, startPos, endPos, parent)
	local obstaclesFolder = makeFolder(parent, "Obstacles")

	local difficulty = clamp((stageIndex - 1) / (STAGES - 1), 0, 1)
	local spike = clamp((stageIndex - 9) / 7, 0, 1)
	local hard = clamp(difficulty * 0.45 + spike * 0.85, 0, 1)

	local count = math.random(3, 7)
	local dir = (endPos - startPos)
	local dist = dir.Magnitude
	if dist < 1 then return end
	dir = dir.Unit

	local baseColor = chooseColor(stageIndex)

	local lateralMax = 8 + math.floor(hard * 22)
	local verticalWave = 3 + math.floor(hard * 10)

	for i = 1, count do
		local t = i / (count + 1)
		local pos = startPos + dir * (dist * t)

		local lateral = (math.random(-lateralMax, lateralMax))
		local up = math.random(-verticalWave, verticalWave)
		local cf = CFrame.new(pos + Vector3.new(lateral, up, 0), pos + Vector3.new(lateral, up, 0) + dir)

		local roll = math.random()
		local obstacleType
		if hard < 0.25 then
			obstacleType = (roll < 0.5) and "Jumps" or "Beam"
		elseif hard < 0.6 then
			obstacleType = (roll < 0.35) and "Moving" or (roll < 0.65) and "Jumps" or "Spinner"
		else
			obstacleType = (roll < 0.25) and "Moving" or (roll < 0.50) and "Falling" or (roll < 0.78) and "Spinner" or "KillLane"
		end

		if obstacleType == "Beam" then
			local length = clamp(34 - math.floor(hard * 18), 14, 34)
			makeNarrowBeam(cf, length, obstaclesFolder, baseColor)

			if stageIndex >= 12 and (math.random() < 0.35) then
				makeKillPart(cf * CFrame.new(0, -3.5, -length / 4), Vector3.new(9, 1.2, 10), obstaclesFolder).Transparency = 0.0
			end

		elseif obstacleType == "Jumps" then
			local pads = clamp(3 + math.floor(hard * 3), 3, 6)
			local spacing = clamp(18 + math.floor(hard * 10), 18, 30)
			makeSmallJumpPads(cf, pads, spacing, obstaclesFolder, stageIndex)

		elseif obstacleType == "Moving" then
			local size = Vector3.new(clamp(18 - math.floor(hard * 8), 9, 18), 2, clamp(18 - math.floor(hard * 8), 9, 18))
			local axis = (math.random() < 0.5) and "X" or "Z"
			local distance = clamp(12 + math.floor(hard * 22), 12, 34)
			local period = clamp(3.2 - hard * 1.2, 1.8, 3.2)
			makeMovingPlatform(cf, size, axis, distance, period, obstaclesFolder, baseColor)

			if math.random() < 0.55 then
				makeKillPart(cf * CFrame.new(0, -9, 0), Vector3.new(size.X + 16, 1.5, size.Z + 16), obstaclesFolder).Transparency = 0.05
			end

		elseif obstacleType == "Falling" then
			local n = clamp(2 + math.floor(hard * 2), 2, 4)
			local step = clamp(18 + math.floor(hard * 12), 18, 30)
			for k = 1, n do
				local size = Vector3.new(clamp(16 - math.floor(hard * 7), 8, 16), 2, clamp(16 - math.floor(hard * 7), 8, 16))
				local cfx = cf * CFrame.new(0, 0, (k - 1) * step)
				makeFallingPlatform(cfx, size, obstaclesFolder, baseColor)
				if math.random() < 0.75 then
					makeKillPart(cfx * CFrame.new(0, -8.5, 0), Vector3.new(size.X + 14, 1.5, size.Z + 14), obstaclesFolder).Transparency = 0.05
				end
			end

		elseif obstacleType == "Spinner" then
			local radius = clamp(6 + hard * 8, 6, 14)
			local bladeLen = clamp(18 + hard * 16, 18, 34)
			local blades = (hard > 0.65) and 4 or 3
			local rpm = clamp(35 + hard * 65, 35, 100)
			makeSpinner(cf * CFrame.new(0, 2.5, 0), radius, bladeLen, blades, rpm, obstaclesFolder, baseColor)
			makeNarrowBeam(cf * CFrame.new(0, -1.5, 0), clamp(26 - math.floor(hard * 10), 14, 26), obstaclesFolder, baseColor)

		elseif obstacleType == "KillLane" then
			local laneLen = clamp(36 + math.floor(hard * 25), 36, 68)
			local lane = makeKillPart(cf * CFrame.new(0, -1.2, 0), Vector3.new(26, 2, laneLen), obstaclesFolder)
			lane.Transparency = 0.0

			local safeCount = clamp(2 + math.floor(hard * 3), 2, 5)
			for s = 1, safeCount do
				local padSize = Vector3.new(clamp(10 - math.floor(hard * 4), 6, 10), 2, clamp(10 - math.floor(hard * 4), 6, 10))
				local z = (-laneLen / 2) + (s * (laneLen / (safeCount + 1)))
				local x = math.random(-9, 9)
				local pad = makePart({
					Name = "SafePad_" .. s,
					Size = padSize,
					CFrame = cf * CFrame.new(x, 0.2, z),
					Color = baseColor,
				})
				addPointLight(pad, baseColor, 2.0, 18)
				pad.Parent = obstaclesFolder
			end
		end
	end
end

