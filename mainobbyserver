local function buildHub(worldFolder)
	local hub = Instance.new("Model")
	hub.Name = "Hub"
	hub.Parent = worldFolder

	local base = makePart({
		Name = "HubBase",
		Size = Vector3.new(120, 3, 120),
		CFrame = CFrame.new(0, BASE_Y - 12, 0),
		Color = COLOR_NEON_BLUE,
	})
	addPointLight(base, COLOR_NEON_BLUE, 2.8, 60)
	base.Parent = hub

	for i = 1, 8 do
		local angle = (i / 8) * math.pi * 2
		local r = 40
		local x = math.cos(angle) * r
		local z = math.sin(angle) * r
		local col = (i % 2 == 0) and COLOR_NEON_PINK or COLOR_NEON_BLUE
		local pillar = makePart({
			Name = "HubPillar_" .. i,
			Size = Vector3.new(6, 26, 6),
			CFrame = CFrame.new(x, BASE_Y - 12 + 13, z),
			Color = col,
			Transparency = 0.15,
		})
		addPointLight(pillar, col, 2.2, 40)
		pillar.Parent = hub
	end

	local spawnPad = makePart({
		Name = "SpawnPad",
		Size = Vector3.new(30, 2, 30),
		CFrame = CFrame.new(0, BASE_Y - 12 + 2.5, 0),
		Color = COLOR_NEON_PINK,
	})
	addPointLight(spawnPad, COLOR_NEON_PINK, 2.6, 40)
	spawnPad.Parent = hub

	local spawnLocation = Instance.new("SpawnLocation")
	spawnLocation.Name = "StartSpawn"
	spawnLocation.Size = Vector3.new(10, 1, 10)
	spawnLocation.Transparency = 1
	spawnLocation.CanCollide = false
	spawnLocation.Anchored = true
	spawnLocation.CFrame = CFrame.new(0, BASE_Y - 12 + 6, 0)
	spawnLocation.Parent = hub

	local board = makePart({
		Name = "LeaderboardBoard",
		Size = Vector3.new(40, 18, 2),
		CFrame = CFrame.new(0, BASE_Y - 12 + 12, -55),
		Color = COLOR_NEON_PURPLE,
		Transparency = 0.15,
		Material = Enum.Material.Neon,
		CanCollide = true,
	})
	addPointLight(board, COLOR_NEON_PURPLE, 2.4, 55)
	board.Parent = hub

	local surface = Instance.new("SurfaceGui")
	surface.Name = "BoardGui"
	surface.Face = Enum.NormalId.Front
	surface.AlwaysOnTop = true
	surface.PixelsPerStud = 60
	surface.Parent = board

	local title = Instance.new("TextLabel")
	title.BackgroundTransparency = 1
	title.Size = UDim2.fromScale(1, 0.18)
	title.Position = UDim2.fromScale(0, 0.02)
	title.Font = Enum.Font.GothamBlack
	title.TextScaled = true
	title.TextColor3 = Color3.fromRGB(255, 255, 255)
	title.TextStrokeTransparency = 0.35
	title.Text = "SERVER LEADERBOARD"
	title.Parent = surface

	local body = Instance.new("TextLabel")
	body.Name = "Body"
	body.BackgroundTransparency = 1
	body.Size = UDim2.fromScale(1, 0.78)
	body.Position = UDim2.fromScale(0, 0.20)
	body.Font = Enum.Font.GothamMedium
	body.TextScaled = false
	body.TextSize = 20
	body.TextColor3 = Color3.fromRGB(230, 240, 255)
	body.TextStrokeTransparency = 0.55
	body.TextXAlignment = Enum.TextXAlignment.Left
	body.TextYAlignment = Enum.TextYAlignment.Top
	body.Text = "Loading..."
	body.Parent = surface

	return hub, spawnLocation, body
end

