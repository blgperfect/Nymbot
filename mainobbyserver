----------------------------------------------------------------
-- HELPERS
----------------------------------------------------------------
local function clamp(x, a, b)
	if x < a then return a end
	if x > b then return b end
	return x
end

local function chooseColor(stageIndex)
	local t = stageIndex % 6
	if t == 0 then return COLOR_NEON_PINK end
	if t == 1 then return COLOR_NEON_BLUE end
	if t == 2 then return COLOR_NEON_PURPLE end
	if t == 3 then return COLOR_NEON_CYAN end
	if t == 4 then return Color3.fromRGB(255, 140, 70) end
	return Color3.fromRGB(255, 255, 90)
end

local function safeDestroy(inst)
	if inst and inst.Parent then
		pcall(function() inst:Destroy() end)
	end
end

local function makeFolder(parent, name)
	local f = parent:FindFirstChild(name)
	if f and f:IsA("Folder") then return f end
	if f then safeDestroy(f) end
	f = Instance.new("Folder")
	f.Name = name
	f.Parent = parent
	return f
end

local function makePart(props)
	local p = Instance.new("Part")
	p.Anchored = true
	p.TopSurface = Enum.SurfaceType.Smooth
	p.BottomSurface = Enum.SurfaceType.Smooth
	p.CanCollide = true
	p.CanQuery = true
	p.CanTouch = true
	p.Material = Enum.Material.Neon
	for k, v in pairs(props or {}) do
		p[k] = v
	end
	return p
end

local function addPointLight(part, color, brightness, range)
	local l = Instance.new("PointLight")
	l.Color = color
	l.Brightness = brightness or 2
	l.Range = range or 18
	l.Parent = part
	return l
end

local function formatTimeSeconds(sec)
	if not sec or sec <= 0 then return "—" end
	local m = math.floor(sec / 60)
	local s = math.floor(sec % 60)
	return string.format("%02d:%02d", m, s)
end

