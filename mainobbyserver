local function hookCharacter(plr, char)
	local uid = plr.UserId
	local hum = char:WaitForChild("Humanoid", 10)
	local hrp = char:WaitForChild("HumanoidRootPart", 10)
	if not hum or not hrp then return end

	task.defer(function()
		local st = session.Stage[uid] or 1
		teleportCharacterToStage(plr, st)
		if st == 1 then
			session.RunStart[uid] = nil
		end
	end)

	hum.Died:Connect(function()
		session.Deaths[uid] = (session.Deaths[uid] or 0) + 1
		markDirty(uid)

		local ls = plr:FindFirstChild("leaderstats")
		if ls then
			local de = ls:FindFirstChild("Deaths")
			if de then de.Value = session.Deaths[uid] end
		end
	end)
end

Players.PlayerAdded:Connect(function(plr)
	local uid = plr.UserId
	local data = loadData(uid)

	session.Stage[uid] = clamp(data.stage, 1, STAGES)
	session.Deaths[uid] = data.deaths
	session.BestTime[uid] = data.bestTime
	session.FreeSkipUsed[uid] = data.freeSkipUsed
	session.RunStart[uid] = nil
	session.Dirty[uid] = nil

	local st, de, bt = ensureLeaderstats(plr)
	st.Value = session.Stage[uid]
	de.Value = session.Deaths[uid]
	bt.Value = session.BestTime[uid]

	plr.CharacterAdded:Connect(function(char)
		hookCharacter(plr, char)
	end)

	if plr.Character then
		hookCharacter(plr, plr.Character)
	end
end)

Players.PlayerRemoving:Connect(function(plr)
	local uid = plr.UserId
	saveData(uid)
	session.Stage[uid] = nil
	session.Deaths[uid] = nil
	session.BestTime[uid] = nil
	session.FreeSkipUsed[uid] = nil
	session.RunStart[uid] = nil
	session.Dirty[uid] = nil
end)

game:BindToClose(function()
	for _, plr in ipairs(Players:GetPlayers()) do
		saveData(plr.UserId)
	end
end)

