local stageModels = {}

local function getStageSpawnCFrame(stageIndex)
	local m = stageModels[stageIndex]
	if not m then return CFrame.new(0, BASE_Y, 0) end
	local plat = m:FindFirstChild("Platform")
	if not plat then return CFrame.new(0, BASE_Y, 0) end
	return plat.CFrame * CFrame.new(0, 6, 0)
end

local function teleportCharacterToStage(plr, stageIndex)
	if not plr.Character then return end
	local hrp = plr.Character:FindFirstChild("HumanoidRootPart")
	local hum = plr.Character:FindFirstChildOfClass("Humanoid")
	if not hrp or not hum then return end
	local cf = getStageSpawnCFrame(stageIndex)
	task.defer(function()
		if hrp and hrp.Parent and hum and hum.Parent then
			hrp.CFrame = cf
			hrp.AssemblyLinearVelocity = Vector3.zero
			hrp.AssemblyAngularVelocity = Vector3.zero
		end
	end)
end

local function ensureLeaderstats(plr)
	local ls = plr:FindFirstChild("leaderstats")
	if not ls then
		ls = Instance.new("Folder")
		ls.Name = "leaderstats"
		ls.Parent = plr
	end

	local function getOrMake(name)
		local v = ls:FindFirstChild(name)
		if v and not v:IsA("IntValue") then safeDestroy(v) v = nil end
		if not v then
			v = Instance.new("IntValue")
			v.Name = name
			v.Parent = ls
		end
		return v
	end

	return getOrMake("Stage"), getOrMake("Deaths"), getOrMake("BestTime")
end

----------------------------------------------------------------
-- SKIP GRANTING
----------------------------------------------------------------
local function grantSkip(plr, reason, notifyEvent)
	local userId = plr.UserId
	local current = session.Stage[userId] or 1
	if current >= STAGES then
		if notifyEvent then notifyEvent:FireClient(plr, "You're already at the final stage.") end
		return
	end

	session.Stage[userId] = clamp(current + 1, 1, STAGES)
	markDirty(userId)

	local st = plr:FindFirstChild("leaderstats") and plr.leaderstats:FindFirstChild("Stage")
	if st then st.Value = session.Stage[userId] end

	if notifyEvent then
		notifyEvent:FireClient(plr, (reason or "Skip granted!") .. (" (Now Stage %d)"):format(session.Stage[userId]))
	end

	teleportCharacterToStage(plr, session.Stage[userId])
end

----------------------------------------------------------------
-- CHECKPOINT TOUCH LOGIC
----------------------------------------------------------------
local function connectCheckpointTouch(stageIndex, circle, notifyEvent)
	circle.Touched:Connect(function(hit)
		local char = hit.Parent
		if not char then return end
		local hum = char:FindFirstChildOfClass("Humanoid")
		if not hum or hum.Health <= 0 then return end
		local plr = Players:GetPlayerFromCharacter(char)
		if not plr then return end

		local userId = plr.UserId
		local currentStage = session.Stage[userId] or 1

		if stageIndex <= currentStage then return end
		if stageIndex ~= currentStage + 1 then return end

		session.Stage[userId] = stageIndex
		markDirty(userId)

		local snd = circle:FindFirstChild("CheckpointSound")
		if snd then pcall(function() snd:Play() end) end

		if stageIndex == 2 then
			session.RunStart[userId] = os.clock()
		end

		if stageIndex == STAGES then
			local started = session.RunStart[userId]
			if started then
				local elapsed = math.max(1, math.floor(os.clock() - started))
				local prev = session.BestTime[userId] or 0
				if prev == 0 or elapsed < prev then
					session.BestTime[userId] = elapsed
					markDirty(userId)
					if notifyEvent then
						notifyEvent:FireClient(plr, "New Best Time: " .. formatTimeSeconds(elapsed))
					end
				end
			end
		end

		local st, de, bt = ensureLeaderstats(plr)
		st.Value = session.Stage[userId] or 1
		de.Value = session.Deaths[userId] or 0
		bt.Value = session.BestTime[userId] or 0

		teleportCharacterToStage(plr, stageIndex)
	end)
end

----------------------------------------------------------------
-- GENERATE OBBY PATH
----------------------------------------------------------------
local function generateCourse(worldFolder, notifyEvent)
	local courseFolder = makeFolder(worldFolder, "Course")

	local pos = Vector3.new(0, BASE_Y, 120)
	local forward = Vector3.new(0, 0, 1)
	local right = Vector3.new(1, 0, 0)

	for stage = 1, STAGES do
		local difficulty = clamp((stage - 1) / (STAGES - 1), 0, 1)
		local spike = clamp((stage - 9) / 7, 0, 1)
		local hard = clamp(difficulty * 0.45 + spike * 0.85, 0, 1)

		local segLen = BASE_SEGMENT_LEN + math.floor(hard * 55)
		local yOff = math.random(-Y_VARIATION, Y_VARIATION) * (0.25 + hard * 0.75)
		local turn = math.random(-1, 1) * (0.1 + hard * 0.22)

		local newDir = (forward + right * turn).Unit
		forward = newDir
		right = Vector3.new(forward.Z, 0, -forward.X)

		local platformPos = pos + forward * segLen + Vector3.new(0, yOff, 0)
		local cframe = CFrame.new(platformPos, platformPos + forward)

		local size = BASE_PLATFORM_SIZE
		if stage >= 10 then
			local shrink = clamp(math.floor(hard * 10), 0, 10)
			size = Vector3.new(
				clamp(BASE_PLATFORM_SIZE.X - shrink, 14, BASE_PLATFORM_SIZE.X),
				2,
				clamp(BASE_PLATFORM_SIZE.Z - shrink, 14, BASE_PLATFORM_SIZE.Z)
			)
		end

		local stageModel, circle = createCheckpointModel(stage, cframe, size, courseFolder)
		stageModels[stage] = stageModel

		connectCheckpointTouch(stage, circle, notifyEvent)

		if stage >= 2 then
			local prevPlat = stageModels[stage - 1]:FindFirstChild("Platform")
			local curPlat = stageModels[stage]:FindFirstChild("Platform")
			if prevPlat and curPlat then
				local segment = Instance.new("Model")
				segment.Name = ("Segment_%02d_to_%02d"):format(stage - 1, stage)
				segment.Parent = courseFolder
				buildObstaclePack(stage, prevPlat.Position + Vector3.new(0, 3, 0), curPlat.Position + Vector3.new(0, 3, 0), segment)
			end
		end

		pos = platformPos
	end
end

