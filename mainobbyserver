local function ensureRemotes()
	local folder = ReplicatedStorage:FindFirstChild(REMOTES_FOLDER)
	if folder and not folder:IsA("Folder") then safeDestroy(folder) end
	if not folder then
		folder = Instance.new("Folder")
		folder.Name = REMOTES_FOLDER
		folder.Parent = ReplicatedStorage
	end

	local function getOrCreate(name, className)
		local r = folder:FindFirstChild(name)
		if r and r.ClassName ~= className then safeDestroy(r) r = nil end
		if not r then
			r = Instance.new(className)
			r.Name = name
			r.Parent = folder
		end
		return r
	end

	local rfGet = getOrCreate("GetClientState", "RemoteFunction")
	local rePaid = getOrCreate("RequestPaidSkip", "RemoteEvent")
	local reFree = getOrCreate("RequestFreeSkip", "RemoteEvent")
	local reNotify = getOrCreate("Notify", "RemoteEvent")

	return folder, rfGet, rePaid, reFree, reNotify
end

----------------------------------------------------------------
-- DATA (buffered autosave)
----------------------------------------------------------------
local store = DataStoreService:GetDataStore(DATASTORE_NAME)

local session = {
	Stage = {},
	Deaths = {},
	BestTime = {},
	FreeSkipUsed = {},
	RunStart = {},
	Dirty = {},
}

local function defaultData()
	return { stage = 1, deaths = 0, bestTime = 0, freeSkipUsed = false }
end

local function loadData(userId)
	local data
	for attempt = 1, LOAD_RETRY do
		local ok, res = pcall(function()
			return store:GetAsync("u_" .. tostring(userId))
		end)
		if ok then
			data = res
			break
		end
		task.wait(0.2 * attempt)
	end
	if type(data) ~= "table" then data = defaultData() end

	data.stage = clamp(tonumber(data.stage) or 1, 1, STAGES)
	data.deaths = tonumber(data.deaths) or 0
	data.bestTime = tonumber(data.bestTime) or 0
	data.freeSkipUsed = (data.freeSkipUsed == true)

	return data
end

local function saveData(userId)
	local data = {
		stage = session.Stage[userId] or 1,
		deaths = session.Deaths[userId] or 0,
		bestTime = session.BestTime[userId] or 0,
		freeSkipUsed = session.FreeSkipUsed[userId] == true,
	}
	for attempt = 1, SAVE_RETRY do
		local ok = pcall(function()
			store:SetAsync("u_" .. tostring(userId), data)
		end)
		if ok then
			session.Dirty[userId] = nil
			return true
		end
		task.wait(0.25 * attempt)
	end
	return false
end

local function markDirty(userId)
	session.Dirty[userId] = true
end

local function startAutosaveLoop()
	task.spawn(function()
		while true do
			task.wait(AUTOSAVE_INTERVAL)
			for _, plr in ipairs(Players:GetPlayers()) do
				local uid = plr.UserId
				if session.Dirty[uid] then
					saveData(uid)
				end
			end
		end
	end)
end

