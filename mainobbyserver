local function startBoardUpdater(boardBodyLabel)
	task.spawn(function()
		while boardBodyLabel and boardBodyLabel.Parent do
			local list = {}
			for _, plr in ipairs(Players:GetPlayers()) do
				local uid = plr.UserId
				table.insert(list, {
					name = plr.Name,
					stage = session.Stage[uid] or 1,
					deaths = session.Deaths[uid] or 0,
					best = session.BestTime[uid] or 0
				})
			end
			table.sort(list, function(a, b)
				if a.stage ~= b.stage then return a.stage > b.stage end
				return a.deaths < b.deaths
			end)

			local lines = {}
			table.insert(lines, "Name              Stage   Deaths   BestTime")
			table.insert(lines, "--------------------------------------------")
			for i = 1, math.min(10, #list) do
				local row = list[i]
				table.insert(lines, string.format("%-16s  %3d/%d    %4d     %s", row.name:sub(1, 16), row.stage, STAGES, row.deaths, formatTimeSeconds(row.best)))
			end
			boardBodyLabel.Text = table.concat(lines, "\n")
			task.wait(2.0)
		end
	end)
end

